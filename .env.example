# StoryFit environment — copy to .env and fill in. All optional: with no keys the
# app runs on the deterministic engine.

# Preferred engine (Claude). new Anthropic() reads these automatically.
ANTHROPIC_API_KEY=
# Custom Anthropic gateway/proxy (optional). Read automatically by the SDK.
ANTHROPIC_BASE_URL=
# Override the Anthropic model. Defaults to a current Sonnet-class model.
STORYFIT_ANTHROPIC_MODEL=

# OpenAI fallback (optional).
OPENAI_API_KEY=
STORYFIT_OPENAI_MODEL=

# Server port. Default 5000; deploy uses 5001.
PORT=5000

# SQLite file path. Default data.db.
STORYFIT_DB=data.db

# Base URL for QA/sim scripts, e.g. http://127.0.0.1:5001
SIM_BASE=

# --- Security (required in production) ---
# Operator password for /admin and operator-only API routes. If unset in
# production, those routes are LOCKED (never open).
CITED_ADMIN_PASSWORD=
# Optional: explicit session-signing secret. Defaults to a hash derived from
# the admin password (changing the password revokes all sessions).
CITED_SESSION_SECRET=
